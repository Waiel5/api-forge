{
  "name": "api-forge",
  "version": "1.2.0",
  "description": "TypeScript-first API framework. Decorators, JWT auth, Zod validation, auto OpenAPI docs. Built on Fastify.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "api",
    "framework",
    "fastify",
    "typescript",
    "decorators",
    "jwt",
    "zod",
    "openapi",
    "swagger",
    "rest",
    "validation",
    "middleware"
  ],
  "author": "waiel <git@waiel.co>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Waiel5/api-forge.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "fastify": "^4.26.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
